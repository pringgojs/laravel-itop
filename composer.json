{
  "name": "pringgojs/laravel-itop",
  "description": "Small Laravel DB-first wrapper for iTop: models, API client and payload builders.",
  "type": "library",
  "license": "MIT",
  "version": "1.0.1",
  "authors": [
    {
      "name": "Pringgojs",
      "email": "odyinggo@gmail.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "illuminate/support": "^8.0|^9.0|^10.0"
  },
  "keywords": [
    "laravel",
    "itop",
    "iTop",
    "integration",
    "wrapper"
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Pringgojs\\LaravelItop\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Pringgojs\\LaravelItop\\LaravelItopServiceProvider"
      ]
    }
  }
}
